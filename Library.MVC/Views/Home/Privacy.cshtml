@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container py-5">
    <div class="text-center mb-4">
        <h1 class="display-4"><i class="bi bi-shield-lock-fill text-primary"></i> Privacy Policy</h1>
        <hr class="my-3" />
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <p>Acme Global College values your privacy. This system collects and stores personal information for:</p>
            <ul>
                <li>Student registration and enrolment</li>
                <li>Attendance tracking</li>
                <li>Academic progress tracking</li>
                <li>Faculty assignment management</li>
            </ul>
            <p>All data is securely stored in our systems and is only accessible to authorized users according to their roles (Admin, Faculty, Student).</p>
            <p>We do not share student or faculty information with third parties without explicit consent.</p>

            <div class="mt-4 text-center">
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                    <i class="bi bi-arrow-left"></i> Back to Home
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
}