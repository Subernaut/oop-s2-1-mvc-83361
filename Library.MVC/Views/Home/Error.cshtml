@model Library.MVC.Models.ErrorViewModel

@{
    ViewData["Title"] = "Application Error";
}

<div class="container py-5">
    <div class="text-center mb-4">
        <h1 class="display-3 text-danger"><i class="bi bi-exclamation-circle-fill"></i> An Error Occurred</h1>
        <p class="lead">We apologize for the inconvenience. Our technical team has been notified and will investigate the issue.</p>
    </div>

    <div class="card shadow-sm text-center">
        <div class="card-body">
            @if (!string.IsNullOrEmpty(Model.RequestId))
            {
                <p><strong>Request ID:</strong> @Model.RequestId</p>
                <p>Please provide this ID to support for assistance.</p>
            }

            <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3">
                <i class="bi bi-house-door-fill"></i> Back to Home
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
}