@model Library.Domain.ExamResult

<h1>Edit</h1>

<form asp-action="Edit">
    <input type="hidden" asp-for="Id" />

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group">
        <label asp-for="StudentProfileId"></label>
        <select asp-for="StudentProfileId" class="form-control" asp-items="ViewBag.StudentProfileId"></select>
    </div>

    <div class="form-group">
        <label asp-for="ExamId"></label>
        <select asp-for="ExamId" class="form-control" asp-items="ViewBag.ExamId"></select>
    </div>

    <div class="form-group">
        <label asp-for="Score"></label>
        <input asp-for="Score" class="form-control" />
        <span asp-validation-for="Score" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="EndDate"></label>
        <input asp-for="EndDate" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
</form>