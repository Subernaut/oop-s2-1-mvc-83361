@model Library.Domain.ExamResult

@{
    ViewData["Title"] = "Exam Result Details";
    bool isAdmin = User.IsInRole("Admin");
}

<h1 class="mb-4"><i class="bi bi-card-text"></i> Exam Result Details</h1>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Student</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.StudentProfile.Name)</dd>

            <dt class="col-sm-3">Exam</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Exam.Title)</dd>

            <dt class="col-sm-3">Score</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Score)</dd>

            <dt class="col-sm-3">Grade</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Grade)</dd>

            <dt class="col-sm-3">End Date</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.EndDate)</dd>
        </dl>

        <div class="d-flex gap-2">
            @if (isAdmin)
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning"><i class="bi bi-pencil-square"></i> Edit</a>
            }
            <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back to List</a>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
}