@model Library.Domain.ExamResult

@{
    ViewData["Title"] = "Create Exam Result";
}

<h1 class="mb-4"><i class="bi bi-plus-circle"></i> Create Exam Result</h1>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="StudentProfileId" class="form-label"><i class="bi bi-person"></i> Student</label>
                <select asp-for="StudentProfileId" class="form-select" asp-items="ViewBag.StudentProfileId"></select>
                <span asp-validation-for="StudentProfileId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ExamId" class="form-label"><i class="bi bi-journal-text"></i> Exam</label>
                <select asp-for="ExamId" class="form-select" asp-items="ViewBag.ExamId"></select>
                <span asp-validation-for="ExamId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Score" class="form-label"><i class="bi bi-bar-chart-line"></i> Score</label>
                <input asp-for="Score" class="form-control" type="number" min="0" />
                <span asp-validation-for="Score" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="EndDate" class="form-label"><i class="bi bi-calendar"></i> End Date</label>
                <input asp-for="EndDate" class="form-control" type="date" />
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Create</button>
                <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
}