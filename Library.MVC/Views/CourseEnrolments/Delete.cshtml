@model Library.Domain.CourseEnrolment

@{
    ViewData["Title"] = "Delete Enrolment";
}

<h1 class="mb-4 text-danger"><i class="bi bi-exclamation-triangle-fill"></i> Delete Enrolment</h1>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h5 class="card-title mb-3">Are you sure you want to delete this enrolment?</h5>
        <hr />

        <dl class="row mb-4">
            <dt class="col-sm-3 fw-bold">Student</dt>
            <dd class="col-sm-9">@Model.StudentProfile.Name</dd>

            <dt class="col-sm-3 fw-bold">Course</dt>
            <dd class="col-sm-9">@Model.Course.Name</dd>

            <dt class="col-sm-3 fw-bold">Enrol Date</dt>
            <dd class="col-sm-9">@Model.EnrolDate.ToString("yyyy-MM-dd")</dd>

            <dt class="col-sm-3 fw-bold">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>
        </dl>

        <form asp-action="Delete" method="post" class="d-flex gap-2">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Delete</button>
            <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back to List</a>
        </form>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
}