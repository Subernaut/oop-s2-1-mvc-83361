@model IEnumerable<Library.Domain.CourseEnrolment>

@{
    ViewData["Title"] = "Course Enrolments";
    var isAdmin = User.IsInRole("Admin");
}

<h1 class="mb-4"><i class="bi bi-journal-check"></i> Course Enrolments</h1>

@if (isAdmin)
{
    <div class="mb-3">
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Create New Enrolment
        </a>
    </div>
}

<table class="table table-hover table-bordered shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>Student</th>
            <th>Course</th>
            <th>Enrol Date</th>
            <th>Status</th>
            <th class="text-center">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    <a asp-controller="StudentProfiles" asp-action="Details" asp-route-id="@item.StudentProfileId">
                        @item.StudentProfile.Name
                    </a>
                </td>
                <td>
                    <a asp-controller="Courses" asp-action="Details" asp-route-id="@item.CourseId">
                        @item.Course.Name
                    </a>
                </td>
                <td>@item.EnrolDate.ToString("yyyy-MM-dd")</td>
                <td>@item.Status</td>
                <td class="text-center">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info me-1">
                        <i class="bi bi-eye"></i> Details
                    </a>
                    @if (isAdmin)
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning text-dark me-1">
                            <i class="bi bi-pencil-square"></i> Edit
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                            <i class="bi bi-trash"></i> Delete
                        </a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
}