@model Library.Domain.CourseEnrolment

@{
    ViewData["Title"] = "Edit Enrolment";
}

<h1 class="mb-4"><i class="bi bi-pencil-square"></i> Edit Enrolment</h1>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="StudentProfileId" class="form-label"><i class="bi bi-person"></i> Student</label>
                <select asp-for="StudentProfileId" class="form-select" asp-items="ViewBag.StudentProfileId"></select>
                <span asp-validation-for="StudentProfileId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="CourseId" class="form-label"><i class="bi bi-book"></i> Course</label>
                <select asp-for="CourseId" class="form-select" asp-items="ViewBag.CourseId"></select>
                <span asp-validation-for="CourseId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="EnrolDate" class="form-label"><i class="bi bi-calendar"></i> Enrol Date</label>
                <input asp-for="EnrolDate" class="form-control" type="date" />
                <span asp-validation-for="EnrolDate" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Status" class="form-label"><i class="bi bi-check2-square"></i> Status</label>
                <select asp-for="Status" class="form-select"></select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2 mt-3">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
}