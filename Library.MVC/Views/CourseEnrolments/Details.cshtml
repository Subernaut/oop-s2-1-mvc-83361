@model Library.Domain.CourseEnrolment

@{
    ViewData["Title"] = "Enrolment Details";
    var isAdmin = User.IsInRole("Admin");
}

<h1 class="mb-4"><i class="bi bi-journal-text"></i> Enrolment Details</h1>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3 fw-bold"><i class="bi bi-person"></i> Student</dt>
            <dd class="col-sm-9">
                <a asp-controller="StudentProfiles" asp-action="Details" asp-route-id="@Model.StudentProfileId">
                    @Model.StudentProfile.Name
                </a>
            </dd>

            <dt class="col-sm-3 fw-bold"><i class="bi bi-book"></i> Course</dt>
            <dd class="col-sm-9">
                <a asp-controller="Courses" asp-action="Details" asp-route-id="@Model.CourseId">
                    @Model.Course.Name
                </a>
            </dd>

            <dt class="col-sm-3 fw-bold"><i class="bi bi-calendar"></i> Enrol Date</dt>
            <dd class="col-sm-9">@Model.EnrolDate.ToString("yyyy-MM-dd")</dd>

            <dt class="col-sm-3 fw-bold"><i class="bi bi-check2-square"></i> Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>
        </dl>
    </div>
</div>

<div class="d-flex gap-2">
    @if (isAdmin)
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning text-dark">
            <i class="bi bi-pencil-square"></i> Edit
        </a>
    }
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Back to List
    </a>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
}