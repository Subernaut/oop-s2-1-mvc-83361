@model Library.Domain.CourseEnrolment

@{
    ViewData["Title"] = "Details";
    var isAdmin = User.IsInRole("Admin");
}

<h1>Details</h1>

<div>
    <h4>Course Enrolment</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Student
        </dt>
        <dd class="col-sm-10">
            <a asp-controller="StudentProfiles" asp-action="Details" asp-route-id="@Model.StudentProfileId">
                @Html.DisplayFor(model => model.StudentProfile.Name)
            </a>
        </dd>

        <dt class="col-sm-2">
            Course
        </dt>
        <dd class="col-sm-10">
            <a asp-controller="Courses" asp-action="Details" asp-route-id="@Model.CourseId">
                @Html.DisplayFor(model => model.Course.Name)
            </a>
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.EnrolDate)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.EnrolDate)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Status)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Status)
        </dd>
    </dl>
</div>

<div>
    @if (isAdmin)
    {
        <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a>
        <span> | </span>
    }
    <a asp-action="Index">Back to List</a>
</div>