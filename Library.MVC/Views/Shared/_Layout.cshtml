@using Microsoft.AspNetCore.Identity
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Library.MVC</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Library.MVC.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Library.MVC</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Assignments" asp-action="Index">Assignments</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="AssignmentResults" asp-action="Index">Assignment Results</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="AttendanceRecords" asp-action="Index">Attendance</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Branches" asp-action="Index">Branches</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Courses" asp-action="Index">Courses</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="CourseEnrolments" asp-action="Index">Enrolments</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Exams" asp-action="Index">Exams</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="ExamResults" asp-action="Index">Exam Results</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="FacultyProfiles" asp-action="Index">Faculty Profiles</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="StudentProfiles" asp-action="Index">Student Profiles</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Users" asp-action="Index">Users</a>
                            </li>
                        }

                        else if (User.IsInRole("Faculty"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Assignments" asp-action="Index">Assignments</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="AssignmentResults" asp-action="Index">Student Gradebook</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="AttendanceRecords" asp-action="Index">Attendance</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Courses" asp-action="Index">Courses</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="CourseEnrolments" asp-action="Index">Enrolments</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Exams" asp-action="Index">Exams</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="ExamResults" asp-action="Index">Exam Results</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="StudentProfiles" asp-action="Index">Students</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="FacultyProfiles" asp-action="Index">My Profile</a>
                            </li>
                        }

                        else if (User.IsInRole("Student"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Assignments" asp-action="Index">Assignments</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="AssignmentResults" asp-action="Index">Gradebook</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="AttendanceRecords" asp-action="Index">Attendance</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Courses" asp-action="Index">My Courses</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="CourseEnrolments" asp-action="Index">My Enrolments</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Exams" asp-action="Index">Exams</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="ExamResults" asp-action="Index">My Results</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="StudentProfiles" asp-action="Index">My Profile</a>
                            </li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Library.MVC - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>