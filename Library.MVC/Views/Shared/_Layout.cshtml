@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Library.MVC</title>

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Library.MVC.styles.css" asp-append-version="true" />

    <!-- Optional icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
</head>
<body>
    @* ---------- C# logic: role-based navbar links ---------- *@
    @{
        var navLinks = new List<dynamic>();
        string username = User.Identity.IsAuthenticated ? User.Identity.Name : "";

        if (User.IsInRole("Admin"))
        {
            navLinks = new List<dynamic> {
    new { Title="Assignments", Controller="Assignments", Action="Index" },
    new { Title="Assignment Results", Controller="AssignmentResults", Action="Index" },
    new { Title="Attendance", Controller="AttendanceRecords", Action="Index" },
    new { Title="Branches", Controller="Branches", Action="Index" },
    new { Title="Courses", Controller="Courses", Action="Index" },
    new { Title="Enrolments", Controller="CourseEnrolments", Action="Index" },
    new { Title="Exams", Controller="Exams", Action="Index" },
    new { Title="Exam Results", Controller="ExamResults", Action="Index" },
    new { Title="Faculty Profiles", Controller="FacultyProfiles", Action="Index" },
    new { Title="Student Profiles", Controller="StudentProfiles", Action="Index" },
    new { Title="Users", Controller="Users", Action="Index" }
    };
        }
        else if (User.IsInRole("Faculty"))
        {
            navLinks = new List<dynamic> {
    new { Title="Assignments", Controller="Assignments", Action="Index" },
    new { Title="Student Gradebook", Controller="AssignmentResults", Action="Index" },
    new { Title="Attendance", Controller="AttendanceRecords", Action="Index" },
    new { Title="Courses", Controller="Courses", Action="Index" },
    new { Title="Enrolments", Controller="CourseEnrolments", Action="Index" },
    new { Title="Exams", Controller="Exams", Action="Index" },
    new { Title="Exam Results", Controller="ExamResults", Action="Index" },
    new { Title="Students", Controller="StudentProfiles", Action="Index" },
    new { Title="My Profile", Controller="FacultyProfiles", Action="Index" }
    };
        }
        else if (User.IsInRole("Student"))
        {
            navLinks = new List<dynamic> {
    new { Title="Assignments", Controller="Assignments", Action="Index" },
    new { Title="Gradebook", Controller="AssignmentResults", Action="Index" },
    new { Title="Attendance", Controller="AttendanceRecords", Action="Index" },
    new { Title="My Courses", Controller="Courses", Action="Index" },
    new { Title="My Enrolments", Controller="CourseEnrolments", Action="Index" },
    new { Title="Exams", Controller="Exams", Action="Index" },
    new { Title="My Results", Controller="ExamResults", Action="Index" },
    new { Title="My Profile", Controller="StudentProfiles", Action="Index" }
    };
        }
    }

    <!-- Navbar -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm mb-4">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-primary" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-building"></i> Library.MVC
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        @foreach (var link in navLinks)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="@link.Controller" asp-action="@link.Action">
                                    @link.Title
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- Main Body -->
    <div class="container">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top bg-light mt-auto">
        <nav class="navbar navbar-expand-sm navbar-light">
            <div class="container-fluid">

                <!-- Left -->
                <span class="navbar-text">
                    &copy; 2026 - Library.MVC -
                    <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                </span>

                <!-- Center (optional spacing helper) -->
                <div class="mx-auto"></div>

                <!-- Right: Login Partial -->
                <div class="d-flex align-items-center">
                    <partial name="_LoginPartial" />
                </div>

            </div>
        </nav>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>