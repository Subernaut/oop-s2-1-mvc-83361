@model Library.Domain.AttendanceRecord

@{
    ViewData["Title"] = "Delete Attendance Record";
}

<h1 class="mb-4 text-danger"><i class="bi bi-exclamation-triangle-fill"></i> Delete Attendance Record</h1>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h5 class="card-title mb-3">Are you sure you want to delete this attendance record?</h5>
        <hr />

        <dl class="row mb-4">
            <dt class="col-sm-3">Student</dt>
            <dd class="col-sm-9">
                <a asp-controller="StudentProfiles" asp-action="Details" asp-route-id="@Model.CourseEnrolment.StudentProfileId">
                    @Model.CourseEnrolment.StudentProfile.Name
                </a>
            </dd>

            <dt class="col-sm-3">Course</dt>
            <dd class="col-sm-9">
                <a asp-controller="Courses" asp-action="Details" asp-route-id="@Model.CourseEnrolment.CourseId">
                    @Model.CourseEnrolment.Course.Name
                </a>
            </dd>

            <dt class="col-sm-3">Date</dt>
            <dd class="col-sm-9">@Model.Date.ToString("yyyy-MM-dd")</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                @if (Model.Present)
                {
                    <span class="badge bg-success">Present</span>
                }
                else
                {
                    <span class="badge bg-danger">Absent</span>
                }
            </dd>
        </dl>

        <form asp-action="Delete" method="post" class="d-flex gap-2">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Delete</button>
            <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back to List</a>
        </form>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
}