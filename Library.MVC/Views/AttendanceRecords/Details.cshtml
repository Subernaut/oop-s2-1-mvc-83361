@model Library.Domain.AttendanceRecord

@{
    ViewData["Title"] = "Attendance Record Details";
    var isFacultyOrAdmin = User.IsInRole("Faculty") || User.IsInRole("Admin");
}

<h1 class="mb-4"><i class="bi bi-journal-text"></i> Attendance Record Details</h1>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3 fw-bold"><i class="bi bi-person"></i> Student</dt>
            <dd class="col-sm-9">
                <a asp-controller="StudentProfiles" asp-action="Details" asp-route-id="@Model.CourseEnrolment.StudentProfileId">
                    @Model.CourseEnrolment.StudentProfile.Name
                </a>
            </dd>

            <dt class="col-sm-3 fw-bold"><i class="bi bi-book"></i> Course</dt>
            <dd class="col-sm-9">
                <a asp-controller="Courses" asp-action="Details" asp-route-id="@Model.CourseEnrolment.CourseId">
                    @Model.CourseEnrolment.Course.Name
                </a>
            </dd>

            <dt class="col-sm-3 fw-bold"><i class="bi bi-calendar-event"></i> Date</dt>
            <dd class="col-sm-9">@Model.Date.ToString("yyyy-MM-dd")</dd>

            <dt class="col-sm-3 fw-bold"><i class="bi bi-check-circle"></i> Status</dt>
            <dd class="col-sm-9">
                @if (Model.Present)
                {
                    <span class="badge bg-success">Present</span>
                }
                else
                {
                    <span class="badge bg-danger">Absent</span>
                }
            </dd>
        </dl>
    </div>
</div>

<div class="d-flex gap-2">
    @if (isFacultyOrAdmin)
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning text-dark">
            <i class="bi bi-pencil-square"></i> Edit
        </a>
    }
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Back to List
    </a>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
}