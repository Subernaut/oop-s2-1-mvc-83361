@model Library.Domain.AttendanceRecord

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Attendance Record</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Student</dt>
        <dd class="col-sm-10">
            <a asp-controller="StudentProfiles" asp-action="Details" asp-route-id="@Model.CourseEnrolment.StudentProfileId">
                @Model.CourseEnrolment.StudentProfile.Name
            </a>
        </dd>

        <dt class="col-sm-2">Course</dt>
        <dd class="col-sm-10">
            <a asp-controller="Courses" asp-action="Details" asp-route-id="@Model.CourseEnrolment.CourseId">
                @Model.CourseEnrolment.Course.Name
            </a>
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Date)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Date)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Present)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Present)
        </dd>
    </dl>
</div>

<div>
    @if (User.IsInRole("Faculty") || User.IsInRole("Admin"))
    {
        <a asp-action="Edit" asp-route-id="@Model.Id">Edit</a> <span>|</span>
    }
    <a asp-action="Index">Back to List</a>
</div>