@model Library.Domain.AttendanceRecord

@{
    ViewData["Title"] = "Create Attendance Record";
}

<h1 class="mb-4"><i class="bi bi-journal-plus"></i> Create Attendance Record</h1>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <!-- Course Enrolment -->
            <div class="mb-3">
                <label asp-for="CourseEnrolmentId" class="form-label"><i class="bi bi-book"></i> Course Enrolment</label>
                <select asp-for="CourseEnrolmentId" class="form-select" asp-items="ViewBag.CourseEnrolmentId"></select>
                <span asp-validation-for="CourseEnrolmentId" class="text-danger"></span>
            </div>

            <!-- Date -->
            <div class="mb-3">
                <label asp-for="Date" class="form-label"><i class="bi bi-calendar-event"></i> Date</label>
                <input asp-for="Date" class="form-control" type="date" />
                <span asp-validation-for="Date" class="text-danger"></span>
            </div>

            <!-- Present -->
            <div class="form-check mb-3">
                <input class="form-check-input" asp-for="Present" />
                <label class="form-check-label" asp-for="Present"><i class="bi bi-check-circle"></i> Present</label>
            </div>

            <!-- Actions -->
            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-plus-circle"></i> Create
                </button>
                <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
}