@model IEnumerable<Library.Domain.AttendanceRecord>

@{
    ViewData["Title"] = "Attendance Records";
    var isStudent = User.IsInRole("Student");
    var isFaculty = User.IsInRole("Faculty");
    var isAdmin = User.IsInRole("Admin");
}

<h1 class="mb-4"><i class="bi bi-journal-check"></i> Attendance Records</h1>

<div class="mb-3">
    @if (isFaculty || isAdmin)
    {
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Create New Record
        </a>
    }
</div>

<table class="table table-hover table-bordered shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>Course</th>
            <th>Student</th>
            <th>Date</th>
            <th>Status</th>
            <th class="text-center">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <!-- Course -->
                <td>
                    <a asp-controller="Courses" asp-action="Details" asp-route-id="@item.CourseEnrolment.CourseId">
                        @item.CourseEnrolment.Course.Name
                    </a>
                </td>

                <!-- Student -->
                <td>
                    <a asp-controller="StudentProfiles" asp-action="Details" asp-route-id="@item.CourseEnrolment.StudentProfileId">
                        @item.CourseEnrolment.StudentProfile.Name
                    </a>
                </td>

                <!-- Date -->
                <td>@item.Date.ToString("yyyy-MM-dd")</td>

                <!-- Present/Absent -->
                <td>
                    @if (item.Present)
                    {
                        <span class="badge bg-success"><i class="bi bi-check-circle"></i> Present</span>
                    }
                    else
                    {
                        <span class="badge bg-danger"><i class="bi bi-x-circle"></i> Absent</span>
                    }
                </td>

                <!-- Actions -->
                <td class="text-center">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info me-1">
                        <i class="bi bi-eye"></i> Details
                    </a>
                    @if (!isStudent)
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning text-dark me-1">
                            <i class="bi bi-pencil-square"></i> Edit
                        </a>
                        @if (isAdmin)
                        {
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                <i class="bi bi-trash"></i> Delete
                            </a>
                        }
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
}