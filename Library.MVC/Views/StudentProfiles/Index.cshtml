@model IEnumerable<Library.Domain.StudentProfile>

@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager

@{
    ViewData["Title"] = "Student Profiles";
    var currentUser = UserManager.GetUserAsync(User).Result;
    var isAdmin = User.IsInRole("Admin");
    var isFaculty = User.IsInRole("Faculty");
}

<h1 class="mb-4"><i class="bi bi-mortarboard-fill"></i> Student Profiles</h1>

@if (isAdmin)
{
    <a asp-action="Create" class="btn btn-success btn-sm mb-3">
        <i class="bi bi-plus-circle"></i> Create New
    </a>
}

<table class="table table-hover table-bordered shadow-sm">
    <thead class="table-dark">
        <tr>
            @if (isAdmin)
            {
                <th>User</th>
            }
            <th>Name</th>
            <th>Email</th>
            @if (isAdmin)
            {
                <th>Phone</th>
                <th>Address</th>
            }
            <th>Student Number</th>
            <th class="text-center">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                @if (isAdmin)
                {
                    <td>@item.Student.Id</td>
                }
                <td>@item.Name</td>
                <td>@item.Email</td>
                @if (isAdmin)
                {
                    <td>@item.Phone</td>
                    <td>@item.Address</td>
                }
                <td>@item.StudentNumber</td>
                <td class="text-center">
                    @if (isAdmin)
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning me-1">
                            <i class="bi bi-pencil-square"></i> Edit
                        </a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info me-1">
                            <i class="bi bi-eye"></i> Details
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                            <i class="bi bi-trash"></i> Delete
                        </a>
                    }
                    else if (isFaculty)
                    {
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">
                            <i class="bi bi-eye"></i> Details
                        </a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
}