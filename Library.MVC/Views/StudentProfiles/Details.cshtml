@model Library.Domain.StudentProfile

@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager

@{
    ViewData["Title"] = "Student Profile Details";
    var currentUser = UserManager.GetUserAsync(User).Result;
    var isAdmin = User.IsInRole("Admin");
    var isFaculty = User.IsInRole("Faculty");
    var isStudent = User.IsInRole("Student") && currentUser.Id == Model.IdentityUserId;
}

<h1 class="mb-4"><i class="bi bi-mortarboard"></i> Student Profile Details</h1>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <dl class="row mb-0">
            @if (isAdmin)
            {
                <dt class="col-sm-3 fw-bold">User</dt>
                <dd class="col-sm-9">
                    <a asp-controller="Users" asp-action="Details" asp-route-id="@Model.Student.Id">
                        @Model.Student.Id
                    </a>
                </dd>
            }

            @if (isAdmin || isStudent || isFaculty)
            {
                <dt class="col-sm-3 fw-bold">Name</dt>
                <dd class="col-sm-9">@Html.DisplayFor(m => m.Name)</dd>

                <dt class="col-sm-3 fw-bold">Email</dt>
                <dd class="col-sm-9">@Html.DisplayFor(m => m.Email)</dd>

                <dt class="col-sm-3 fw-bold">Phone</dt>
                <dd class="col-sm-9">@Html.DisplayFor(m => m.Phone)</dd>

                <dt class="col-sm-3 fw-bold">Address</dt>
                <dd class="col-sm-9">@Html.DisplayFor(m => m.Address)</dd>

                <dt class="col-sm-3 fw-bold">Student Number</dt>
                <dd class="col-sm-9">@Html.DisplayFor(m => m.StudentNumber)</dd>
            }
        </dl>
    </div>
</div>

<div class="d-flex gap-2">
    @if (isAdmin)
    {
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning"><i class="bi bi-pencil-square"></i> Edit</a>
    }
    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back to List</a>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
}