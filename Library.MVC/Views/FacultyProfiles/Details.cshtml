@model Library.Domain.FacultyProfile

@{
    ViewData["Title"] = "Faculty Profile Details";
}

<h1 class="mb-4"><i class="bi bi-person-badge"></i> Faculty Profile Details</h1>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3 fw-bold">User</dt>
            <dd class="col-sm-9">@Model.Faculty.Id</dd>

            <dt class="col-sm-3 fw-bold">Name</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Name)</dd>

            <dt class="col-sm-3 fw-bold">Email</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Email)</dd>

            <dt class="col-sm-3 fw-bold">Phone</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Phone)</dd>
        </dl>
    </div>
</div>

<div class="d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning"><i class="bi bi-pencil-square"></i> Edit</a>
    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back to List</a>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
}