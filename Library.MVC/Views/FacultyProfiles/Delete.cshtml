@model Library.Domain.FacultyProfile

@{
    ViewData["Title"] = "Delete Faculty Profile";
}

<h1 class="mb-4 text-danger"><i class="bi bi-exclamation-triangle-fill"></i> Delete Faculty Profile</h1>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h5 class="card-title mb-3">Are you sure you want to delete this faculty profile?</h5>
        <hr />
        <dl class="row mb-4">
            <dt class="col-sm-3">User</dt>
            <dd class="col-sm-9">@Model.Faculty.Id</dd>

            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Name)</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Email)</dd>

            <dt class="col-sm-3">Phone</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Phone)</dd>
        </dl>

        <form asp-action="Delete" method="post" class="d-flex gap-2">
            <input type="hidden" asp-for="Id" />
            <input type="submit" value="Delete" class="btn btn-danger" />
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </form>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
}