@model Library.Domain.FacultyProfile

@{
    ViewData["Title"] = "Create Faculty Profile";
}

<h1 class="mb-4"><i class="bi bi-person-badge-fill"></i> Create Faculty Profile</h1>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <!-- User -->
            <div class="mb-3">
                <label asp-for="IdentityUserId" class="form-label"><i class="bi bi-person"></i> User</label>
                <select asp-for="IdentityUserId" class="form-select" asp-items="ViewBag.IdentityUserId"></select>
                <span asp-validation-for="IdentityUserId" class="text-danger"></span>
            </div>

            <!-- Name -->
            <div class="mb-3">
                <label asp-for="Name" class="form-label"><i class="bi bi-person-lines-fill"></i> Name</label>
                <input asp-for="Name" class="form-control" placeholder="Enter full name" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <!-- Email -->
            <div class="mb-3">
                <label asp-for="Email" class="form-label"><i class="bi bi-envelope"></i> Email</label>
                <input asp-for="Email" class="form-control" placeholder="Enter email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <!-- Phone -->
            <div class="mb-3">
                <label asp-for="Phone" class="form-label"><i class="bi bi-telephone"></i> Phone</label>
                <input asp-for="Phone" class="form-control" placeholder="Enter phone number" />
                <span asp-validation-for="Phone" class="text-danger"></span>
            </div>

            <!-- Actions -->
            <div class="d-flex gap-2 mt-3">
                <input type="submit" value="Create" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
}