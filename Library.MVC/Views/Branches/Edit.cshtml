@model Library.Domain.Branch

@{
    ViewData["Title"] = "Edit Branch";
}

<h1 class="mb-4"><i class="bi bi-pencil-square"></i> Edit Branch</h1>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="Name" class="form-label"><i class="bi bi-tags"></i> Name</label>
                <input asp-for="Name" class="form-control" placeholder="Enter branch name" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Address" class="form-label"><i class="bi bi-geo-alt"></i> Address</label>
                <input asp-for="Address" class="form-control" placeholder="Enter branch address" />
                <span asp-validation-for="Address" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2 mt-3">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
}