@model IEnumerable<Library.Domain.AssignmentResult>

@{
    ViewData["Title"] = "Assignment Results";
    var role = ViewData["Role"] as string ?? "Unknown";
}

<div class="container mt-4">

    <!-- Top bar: title & create button -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap">
        <h1 class="mb-0"><i class="bi bi-journal-text"></i> Assignment Results</h1>

        @if (role == "Faculty" || role == "Admin")
        {
            <div class="text-end my-2">
                <a asp-action="Create" class="btn btn-success btn-sm">
                    <i class="bi bi-plus-circle"></i> Create New
                </a>
            </div>
        }
    </div>

    <!-- Table -->
    <div class="table-responsive shadow-sm">
        <table class="table table-hover table-bordered align-middle" style="width:95%;" id="resultsTable">
            <thead class="table-dark">
                <tr>
                    <th>Assignment</th>
                    <th>Student</th>
                    <th>Score</th>
                    <th>Feedback</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @if (role == "Faculty" || role == "Admin")
                            {
                                <a asp-controller="Assignments" asp-action="Details" asp-route-id="@item.AssignmentId">
                                    @item.Assignment.Title
                                </a>
                            }
                            else
                            {
                                @item.Assignment.Title
                            }
                        </td>
                        <td>
                            @if (role == "Faculty" || role == "Admin")
                            {
                                <a asp-controller="StudentProfiles" asp-action="Details" asp-route-id="@item.StudentProfileId">
                                    @item.StudentProfile.Name
                                </a>
                            }
                            else
                            {
                                @item.StudentProfile.Name
                            }
                        </td>
                        <td>@item.Score</td>
                        <td>@item.Feedback</td>
                        <td class="text-center">
                            <div class="btn-group btn-group-sm" role="group">
                                @if (role == "Faculty" || role == "Admin")
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary">
                                        <i class="bi bi-pencil-square"></i> Edit
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info">
                                        <i class="bi bi-eye"></i> Details
                                    </a>
                                    @if (role == "Admin")
                                    {
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger">
                                            <i class="bi bi-trash"></i> Delete
                                        </a>
                                    }
                                }
                                else
                                {
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info">
                                        <i class="bi bi-eye"></i> Details
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
}