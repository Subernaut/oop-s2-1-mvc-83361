@model IEnumerable<Library.Domain.AssignmentResult>

@{
    ViewData["Title"] = "Assignment Results";
    var role = ViewData["Role"] as string ?? "Unknown";
}

<div class="container mt-4">
    <h2>@ViewData["Title"]</h2>

    @if (role == "Faculty" || role == "Admin")
    {
        <p>
            <a asp-action="Create" class="btn btn-success">Create New</a>
        </p>
    }

    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Assignment</th>
                <th>Student</th>
                <th>Score</th>
                <th>Feedback</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <!-- ASSIGNMENT -->
                    <td>
                        @if (role == "Faculty" || role == "Admin")
                        {
                            <a asp-controller="Assignments" asp-action="Details" asp-route-id="@item.AssignmentId">
                                @item.Assignment.Title
                            </a>
                        }
                        else
                        {
                            @item.Assignment.Title
                        }
                    </td>

                    <!-- STUDENT -->
                    <td>
                        @if (role == "Faculty" || role == "Admin")
                        {
                            <a asp-controller="StudentProfiles" asp-action="Details" asp-route-id="@item.StudentProfileId">
                                @item.StudentProfile.Name
                            </a>
                        }
                        else
                        {
                            @item.StudentProfile.Name
                        }
                    </td>

                    <!-- SCORE -->
                    <td>@item.Score</td>

                    <!-- FEEDBACK -->
                    <td>@item.Feedback</td>

                    <!-- ACTIONS -->
                    <td>
                        @if (role == "Faculty" || role == "Admin")
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Edit</a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                            @if (role == "Admin")
                            {
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                            }
                        }
                        else
                        {
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <!-- Optional: Add some Bootstrap JS for responsive table -->
    <script>
        console.log("Assignment Results page loaded for role: '@role'");
    </script>
}