@model Library.Domain.AssignmentResult

@{
    ViewData["Title"] = "Create Assignment Result";
}

<h1 class="mb-4"><i class="bi bi-journal-plus"></i> Create Assignment Result</h1>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <!-- Assignment -->
            <div class="mb-3">
                <label asp-for="AssignmentId" class="form-label"><i class="bi bi-journal-text"></i> Assignment</label>
                <select asp-for="AssignmentId" class="form-select" asp-items="ViewBag.AssignmentId"></select>
                <span asp-validation-for="AssignmentId" class="text-danger"></span>
            </div>

            <!-- Student -->
            <div class="mb-3">
                <label asp-for="StudentProfileId" class="form-label"><i class="bi bi-person"></i> Student</label>
                <select asp-for="StudentProfileId" class="form-select" asp-items="ViewBag.StudentProfileId"></select>
                <span asp-validation-for="StudentProfileId" class="text-danger"></span>
            </div>

            <!-- Score -->
            <div class="mb-3">
                <label asp-for="Score" class="form-label"><i class="bi bi-bar-chart-line"></i> Score</label>
                <input asp-for="Score" class="form-control" placeholder="Enter score" />
                <span asp-validation-for="Score" class="text-danger"></span>
            </div>

            <!-- Feedback -->
            <div class="mb-3">
                <label asp-for="Feedback" class="form-label"><i class="bi bi-chat-left-text"></i> Feedback</label>
                <textarea asp-for="Feedback" class="form-control" rows="3" placeholder="Enter feedback"></textarea>
                <span asp-validation-for="Feedback" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-plus-circle"></i> Create
                </button>
                <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
}