@model Library.Domain.Exam

@{
    ViewData["Title"] = "Exam Details";
    var examResults = ViewData["ExamResults"] as List<Library.Domain.ExamResult>;
    var myExamResult = ViewData["MyExamResult"] as Library.Domain.ExamResult;
}

<h1 class="mb-4"><i class="bi bi-journal-text"></i> Exam Details</h1>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3 fw-bold"><i class="bi bi-card-text"></i> Title</dt>
            <dd class="col-sm-9">@Model.Title</dd>

            <dt class="col-sm-3 fw-bold"><i class="bi bi-book"></i> Course</dt>
            <dd class="col-sm-9">@Model.Course.Name</dd>

            <dt class="col-sm-3 fw-bold"><i class="bi bi-calendar"></i> Date</dt>
            <dd class="col-sm-9">@Model.Date.ToString("yyyy-MM-dd")</dd>

            <dt class="col-sm-3 fw-bold"><i class="bi bi-bar-chart-line"></i> Max Score</dt>
            <dd class="col-sm-9">@Model.MaxScore</dd>

            <dt class="col-sm-3 fw-bold"><i class="bi bi-check2-square"></i> Results Released</dt>
            <dd class="col-sm-9">@Model.ResultsReleased</dd>
        </dl>
    </div>
</div>

@if ((User.IsInRole("Admin") || User.IsInRole("Faculty")) && examResults != null && examResults.Any())
{
    <h4>Exam Results</h4>
    <ul class="list-group mb-4">
        @foreach (var result in examResults)
        {
            <li class="list-group-item">
                <a asp-action="Details" asp-controller="ExamResults" asp-route-id="@result.Id">
                    @result.StudentProfile?.Name
                </a>
            </li>
        }
    </ul>
}
else if (User.IsInRole("Student") && myExamResult != null)
{
    <h4>My Exam Result</h4>
    <a asp-action="Details" asp-controller="ExamResults" asp-route-id="@myExamResult.Id" class="btn btn-info">
        <i class="bi bi-eye"></i> View My Result
    </a>
}

<div class="mt-3">
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning text-dark me-2">
            <i class="bi bi-pencil-square"></i> Edit
        </a>
    }
    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back to List</a>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
}