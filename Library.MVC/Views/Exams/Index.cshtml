@model IEnumerable<Library.Domain.Exam>

@{
    ViewData["Title"] = "Exams";
    bool isAdmin = User.IsInRole("Admin");
    bool isStudent = User.IsInRole("Student");
}

<h1 class="mb-4"><i class="bi bi-pencil-square"></i> Exams</h1>

@if (isAdmin)
{
    <div class="mb-3">
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Create New Exam
        </a>
    </div>
}

<table class="table table-hover table-bordered shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>Title</th>
            <th>Course</th>
            <th>Date</th>
            <th>Max Score</th>
            <th>Results Released</th>
            <th class="text-center">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var exam in Model)
        {
            <tr>
                <td>@exam.Title</td>
                <td>@exam.Course.Name</td>
                <td>@exam.Date.ToString("yyyy-MM-dd")</td>
                <td>@exam.MaxScore</td>
                <td>@exam.ResultsReleased</td>
                <td class="text-center">
                    <a asp-action="Details" asp-route-id="@exam.Id" class="btn btn-sm btn-info me-1">
                        <i class="bi bi-eye"></i> Details
                    </a>
                    @if (isAdmin)
                    {
                        <a asp-action="Edit" asp-route-id="@exam.Id" class="btn btn-sm btn-warning text-dark me-1">
                            <i class="bi bi-pencil-square"></i> Edit
                        </a>
                        <a asp-action="Delete" asp-route-id="@exam.Id" class="btn btn-sm btn-danger">
                            <i class="bi bi-trash"></i> Delete
                        </a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
}