@model dynamic

@{
    ViewData["Title"] = "Details";
    var user = Model.User;
    var roles = Model.Roles as IEnumerable<string> ?? new string[] { };
    var profile = Model.Profile; // Could be StudentProfile, FacultyProfile, or null
    var role = roles.FirstOrDefault() ?? "Unknown";
}

<h1 class="mb-4"><i class="bi bi-person-circle"></i> User Details</h1>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0">@user.Email</h5>
        <small class="badge bg-light text-dark">@role</small>
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3 fw-bold">Email</dt>
            <dd class="col-sm-9">@user.Email</dd>

            <dt class="col-sm-3 fw-bold">Role</dt>
            <dd class="col-sm-9">
                <span class="badge
                    @(role == "Admin" ? "bg-success" : role == "Student" ? "bg-info" : "bg-warning")">
                    @role
                </span>
            </dd>

            @if (role == "Student" && profile != null)
            {
                <dt class="col-sm-3 fw-bold">Student Profile</dt>
                <dd class="col-sm-9">
                    <a class="btn btn-sm btn-outline-info"
                       asp-controller="StudentProfiles"
                       asp-action="Details"
                       asp-route-id="@profile.Id">
                        <i class="bi bi-mortarboard"></i> View Student Profile
                    </a>
                </dd>
            }
            else if (role == "Faculty" && profile != null)
            {
                <dt class="col-sm-3 fw-bold">Faculty Profile</dt>
                <dd class="col-sm-9">
                    <a class="btn btn-sm btn-outline-warning"
                       asp-controller="FacultyProfiles"
                       asp-action="Details"
                       asp-route-id="@profile.Id">
                        <i class="bi bi-person-badge"></i> View Faculty Profile
                    </a>
                </dd>
            }
            else
            {
                <dt class="col-sm-3 fw-bold">Profile</dt>
                <dd class="col-sm-9 text-muted">No linked profile</dd>
            }
        </dl>
    </div>
</div>

<div class="d-flex gap-2">
    <a class="btn btn-primary" asp-action="Edit" asp-route-id="@user.Id">
        <i class="bi bi-pencil-square"></i> Edit
    </a>
    <a class="btn btn-secondary" asp-action="Index">
        <i class="bi bi-arrow-left"></i> Back to List
    </a>
</div>

@section Scripts {
    <!-- Optional: Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
}