@model dynamic

@{
    ViewData["Title"] = "Edit User";
    var rolesList = ViewData["Roles"] as string[] ?? new string[] { };
    var selectedRole = (Model.Roles as IEnumerable<string>)?.FirstOrDefault() ?? "";
}

<h1 class="mb-4"><i class="bi bi-pencil-square"></i> Edit User</h1>

<div class="card shadow-sm">
    <div class="card-body">
        <h5 class="card-title mb-3">User Details</h5>
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <!-- Hidden ID -->
            <input type="hidden" name="id" value="@Model.User.Id" />

            <!-- Email -->
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" name="email" class="form-control" value="@Model.User.Email" />
            </div>

            <!-- Role -->
            <div class="mb-3">
                <label class="form-label">Role</label>
                <select name="role" class="form-select">
                    @foreach (var role in rolesList)
                    {
                        <option value="@role" selected="@(role == selectedRole)">
                            @role
                        </option>
                    }
                </select>
            </div>

            <!-- Submit -->
            <div class="mt-4">
                <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Save</button>
                <a asp-action="Index" class="btn btn-secondary ms-2"><i class="bi bi-arrow-left"></i> Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <!-- Optional: Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}